@model MicrobloggingSystem.Models.ViewModels.ReportsViewModel

<h1 class="mb-4">Reports</h1>

<div class="row">
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Top 5 Users by Followers</div>
            <div class="card-body">
                <ul class="list-group list-group-flush">
                    @foreach (var user in Model.TopUsers)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            @user.DisplayName
                            <span class="badge bg-primary">@user.FollowersCount</span>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </div>
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header">Most Engaging Post</div>
            <div class="card-body">
                @if (Model.PopularPost == null)
                {
                    <div class="text-muted">No posts yet.</div>
                }
                else
                {
                    <h5>@Model.PopularPost.UserDisplayName</h5>
                    <p>@Model.PopularPost.Content</p>
                    <p class="small text-muted">@Model.PopularPost.CommentsCount comments · @Model.PopularPost.LikesCount likes</p>
                }
            </div>
        </div>
    </div>
</div>

<div class="card">
    <div class="card-header">Average Posts per User</div>
    <div class="card-body">
        <p class="mb-0">@Model.AveragePostsPerUser:F2 posts per user</p>
    </div>
</div>
