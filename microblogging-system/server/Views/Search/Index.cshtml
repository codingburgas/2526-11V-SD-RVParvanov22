@{
    ViewData["Title"] = "Search";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <h1 class="mb-4">Search</h1>

            <!-- Search Form -->
            <div class="card mb-4">
                <div class="card-body">
                    <form method="get" action="@Url.Action("Index", "Search")" class="mb-3">
                        <div class="input-group">
                            <input type="text"
                                   name="q"
                                   class="form-control"
                                   placeholder="Search for users, posts, or content..."
                                   value="@ViewBag.Query"
                                   required>
                            <select name="type" class="form-select" style="max-width: 150px;">
                                <option value="all" selected="@(ViewBag.Type == "all")">All</option>
                                <option value="users" selected="@(ViewBag.Type == "users")">Users</option>
                                <option value="posts" selected="@(ViewBag.Type == "posts")">Posts</option>
                            </select>
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(ViewBag.Query))
            {
                <!-- Search Results -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Search Results for "@ViewBag.Query"</h5>
                    </div>
                    <div class="card-body">
                        @if (ViewBag.Type == "users" || ViewBag.Type == "all")
                        {
                            <div class="mb-4">
                                <h6>Users</h6>
                                <a href="@Url.Action("Users", "Search", new { q = ViewBag.Query })" class="btn btn-sm btn-outline-primary mb-2">
                                    View all user results
                                </a>
                            </div>
                        }

                        @if (ViewBag.Type == "posts" || ViewBag.Type == "all")
                        {
                            <div class="mb-4">
                                <h6>Posts</h6>
                                <a href="@Url.Action("Posts", "Search", new { q = ViewBag.Query })" class="btn btn-sm btn-outline-primary mb-2">
                                    View all post results
                                </a>
                            </div>
                        }
                    </div>
                </div>
            }
            else
            {
                <!-- Search Tips -->
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Search Tips</h5>
                    </div>
                    <div class="card-body">
                        <ul class="mb-0">
                            <li>Search for users by their display name, username, or region</li>
                            <li>Search for posts by content, game title, or author</li>
                            <li>Use specific keywords to narrow down your results</li>
                        </ul>
                    </div>
                </div>
            }
        </div>
    </div>
</div>