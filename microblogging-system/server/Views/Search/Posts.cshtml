@model IEnumerable<MicrobloggingSystem.Models.DTOs.PostResponseDto>

@{
    ViewData["Title"] = "Search Posts";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Search Posts</h1>
                <a href="@Url.Action("Index", "Search")" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left"></i> Back to Search
                </a>
            </div>

            <!-- Search Form -->
            <div class="card mb-4">
                <div class="card-body">
                    <form method="get" action="@Url.Action("Posts", "Search")" class="mb-0">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <input type="text"
                                       name="q"
                                       class="form-control"
                                       placeholder="Search posts..."
                                       value="@ViewBag.Query">
                            </div>
                            <div class="col-md-3">
                                <input type="text"
                                       name="gameTitle"
                                       class="form-control"
                                       placeholder="Game title (optional)"
                                       value="@ViewBag.GameTitle">
                            </div>
                            <div class="col-md-3">
                                <select name="postType" class="form-select">
                                    <option value="">All post types</option>
                                    <option value="achievement" selected="@(ViewBag.PostType == "achievement")">Achievement</option>
                                    <option value="match_result" selected="@(ViewBag.PostType == "match_result")">Match Result</option>
                                    <option value="discussion" selected="@(ViewBag.PostType == "discussion")">Discussion</option>
                                    <option value="general" selected="@(ViewBag.PostType == "general")">General</option>
                                </select>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-search"></i> Search
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Error"]
                </div>
            }

            @if (!string.IsNullOrEmpty(ViewBag.Query) || !string.IsNullOrEmpty(ViewBag.GameTitle) || !string.IsNullOrEmpty(ViewBag.PostType))
            {
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Posts matching your search</h5>
                    </div>
                    <div class="card-body">
                        @if (Model != null && Model.Any())
                        {
                            @foreach (var post in Model)
                            {
                                <div class="card mb-3">
                                    <div class="card-body">
                                        <div class="d-flex align-items-start mb-2">
                                            @if (!string.IsNullOrEmpty(post.UserProfilePictureUrl))
                                            {
                                                <img src="@post.UserProfilePictureUrl"
                                                     alt="@post.UserDisplayName"
                                                     class="rounded-circle me-3"
                                                     style="width: 40px; height: 40px; object-fit: cover;">
                                            }
                                            else
                                            {
                                                <div class="bg-secondary rounded-circle me-3 d-flex align-items-center justify-content-center"
                                                     style="width: 40px; height: 40px;">
                                                    <i class="fas fa-user text-white" style="font-size: 16px;"></i>
                                                </div>
                                            }

                                            <div class="flex-grow-1">
                                                <div class="d-flex align-items-center mb-1">
                                                    <strong class="me-2">
                                                        <a href="@Url.Action("Profile", "Account", new { id = post.UserId })"
                                                           class="text-decoration-none">
                                                            @post.UserDisplayName
                                                        </a>
                                                    </strong>
                                                    <small class="text-muted">
                                                        @post.CreatedAt.ToString("MMM dd, yyyy 'at' HH:mm")
                                                    </small>
                                                </div>

                                                @if (!string.IsNullOrEmpty(post.GameTitle))
                                                {
                                                    <div class="mb-2">
                                                        <span class="badge bg-primary">@post.GameTitle</span>
                                                    </div>
                                                }

                                                <p class="mb-2">@post.Content</p>

                                                @if (!string.IsNullOrEmpty(post.MediaPath))
                                                {
                                                    <div class="mb-2">
                                                        @if (post.MediaType?.StartsWith("image/") == true)
                                                        {
                                                            <img src="@post.MediaPath"
                                                                 alt="Post media"
                                                                 class="img-fluid rounded"
                                                                 style="max-height: 300px;">
                                                        }
                                                        else if (post.MediaType?.StartsWith("video/") == true)
                                                        {
                                                            <video controls class="w-100 rounded" style="max-height: 300px;">
                                                                <source src="@post.MediaPath" type="@post.MediaType">
                                                                Your browser does not support the video tag.
                                                            </video>
                                                        }
                                                    </div>
                                                }

                                                <div class="d-flex align-items-center">
                                                    <small class="text-muted me-3">
                                                        <i class="fas fa-heart"></i> @post.LikesCount like@(post.LikesCount != 1 ? "s" : "")
                                                    </small>
                                                    <small class="text-muted me-3">
                                                        <i class="fas fa-comment"></i> @post.CommentsCount comment@(post.CommentsCount != 1 ? "s" : "")
                                                    </small>
                                                    <a href="@Url.Action("Details", "PostsMvc", new { id = post.Id })"
                                                       class="btn btn-sm btn-outline-primary">
                                                        View Details
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            }

                            <!-- Pagination -->
                            @if (ViewBag.Page > 1 || (Model.Count() == ViewBag.PageSize))
                            {
                                <nav aria-label="Post search pagination" class="mt-4">
                                    <ul class="pagination justify-content-center">
                                        @if (ViewBag.Page > 1)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="@Url.Action("Posts", "Search", new { q = ViewBag.Query, gameTitle = ViewBag.GameTitle, postType = ViewBag.PostType, page = ViewBag.Page - 1, pageSize = ViewBag.PageSize })">
                                                    Previous
                                                </a>
                                            </li>
                                        }

                                        <li class="page-item active">
                                            <span class="page-link">@ViewBag.Page</span>
                                        </li>

                                        @if (Model.Count() == ViewBag.PageSize)
                                        {
                                            <li class="page-item">
                                                <a class="page-link" href="@Url.Action("Posts", "Search", new { q = ViewBag.Query, gameTitle = ViewBag.GameTitle, postType = ViewBag.PostType, page = ViewBag.Page + 1, pageSize = ViewBag.PageSize })">
                                                    Next
                                                </a>
                                            </li>
                                        }
                                    </ul>
                                </nav>
                            }
                        }
                        else
                        {
                            <div class="text-center py-4">
                                <i class="fas fa-search fa-3x text-muted mb-3"></i>
                                <h5 class="text-muted">No posts found</h5>
                                <p class="text-muted">Try adjusting your search terms or filters.</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>