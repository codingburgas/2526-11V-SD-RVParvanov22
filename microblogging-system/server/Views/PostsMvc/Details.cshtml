@model MicrobloggingSystem.Models.ViewModels.PostDetailsViewModel

<h1 class="mb-4">Post Details</h1>

<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between">
            <div>
                <h5>@Model.Post.UserDisplayName</h5>
                <p class="text-muted mb-1">@Model.Post.CreatedAt.ToLocalTime().ToString("g")</p>
            </div>
            <span class="badge bg-secondary">@Model.Post.PostType ?? "General"</span>
        </div>
        <p class="mt-3">@Model.Post.Content</p>
        <div class="d-flex justify-content-between small text-muted">
            <span>@Model.Post.CommentsCount comments</span>
            <span>@Model.Post.LikesCount likes</span>
        </div>
        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Post.Id" class="btn btn-outline-primary btn-sm">Edit</a>
            <form asp-action="Delete" method="post" class="d-inline ms-2">
                <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
            </form>
        </div>
    </div>
</div>

<h2 class="h5">Comments</h2>

@if (!Model.Comments.Any())
{
    <div class="alert alert-secondary">No comments yet. Be the first to respond.</div>
}
else
{
    foreach (var comment in Model.Comments)
    {
        <div class="card mb-2">
            <div class="card-body">
                <p class="mb-1">@comment.Content</p>
                <div class="small text-muted">@comment.UserDisplayName · @comment.CreatedAt.ToLocalTime().ToString("g")</div>
            </div>
        </div>
    }
}

@if (User.Identity?.IsAuthenticated == true)
{
    <div class="card mt-4">
        <div class="card-body">
            <h5 class="card-title">Add a comment</h5>
            <form asp-controller="CommentMvc" asp-action="Create" method="post">
                <input asp-for="NewComment.PostId" type="hidden" />
                <div class="mb-3">
                    <textarea asp-for="NewComment.Content" class="form-control" rows="3" maxlength="280"></textarea>
                    <span asp-validation-for="NewComment.Content" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary">Post Comment</button>
            </form>
        </div>
    </div>
}
else
{
    <div class="alert alert-info mt-4">Please <a asp-controller="Account" asp-action="Login">login</a> to comment.</div>
}
