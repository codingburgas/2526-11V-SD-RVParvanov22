@model MicrobloggingSystem.Models.DTOs.ReportResponseDto

@section Styles {
    <link rel="stylesheet" href="~/css/feed.css" asp-append-version="true" />
}

<h1 class="mb-4 feed-page-title">Report Details</h1>

<div class="card">
    <div class="card-header">
        <h5>Report #@Model.Id</h5>
        <span class="badge bg-@(Model.Status == ReportStatus.Pending ? "warning" : Model.Status == ReportStatus.Reviewed ? "success" : "secondary")">
            @Model.Status
        </span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <h6>Report Information</h6>
                <table class="table table-sm">
                    <tr>
                        <td><strong>Report ID:</strong></td>
                        <td>@Model.Id</td>
                    </tr>
                    <tr>
                        <td><strong>Reported by:</strong></td>
                        <td>@Model.ReporterDisplayName</td>
                    </tr>
                    <tr>
                        <td><strong>Reason:</strong></td>
                        <td>@Model.Reason</td>
                    </tr>
                    <tr>
                        <td><strong>Status:</strong></td>
                        <td>@Model.Status</td>
                    </tr>
                    <tr>
                        <td><strong>Created:</strong></td>
                        <td>@Model.CreatedAt.ToLocalTime().ToString("g")</td>
                    </tr>
                    @if (Model.ReviewedAt.HasValue)
                    {
                        <tr>
                            <td><strong>Reviewed:</strong></td>
                            <td>@Model.ReviewedAt.Value.ToLocalTime().ToString("g")</td>
                        </tr>
                        <tr>
                            <td><strong>Reviewed by:</strong></td>
                            <td>@Model.ReviewerDisplayName</td>
                        </tr>
                        <tr>
                            <td><strong>Action taken:</strong></td>
                            <td>@Model.ActionTaken</td>
                        </tr>
                    }
                </table>
            </div>
            <div class="col-md-6">
                <h6>Reported Post</h6>
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title">@Model.PostGameTitle</h6>
                        <p class="card-text">@Model.PostContent</p>
                        <p class="card-text"><small class="text-muted">By: @Model.PostAuthorDisplayName</small></p>
                        <a asp-controller="PostsMvc" asp-action="Details" asp-route-id="@Model.PostId" class="btn btn-primary btn-sm">View Post</a>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Description))
        {
            <div class="mt-3">
                <h6>Report Description</h6>
                <p>@Model.Description</p>
            </div>
        }
    </div>
    <div class="card-footer">
        <a asp-action="Index" class="btn btn-secondary">Back to Reports</a>

        @if (Model.Status == ReportStatus.Pending)
        {
            <form asp-action="Review" method="post" class="d-inline">
                <input type="hidden" name="id" value="@Model.Id" />
                <div class="d-inline-block me-2">
                    <select name="status" class="form-select form-select-sm" required>
                        <option value="Reviewed">Mark as Reviewed</option>
                        <option value="Resolved">Mark as Resolved</option>
                    </select>
                </div>
                <div class="d-inline-block me-2">
                    <select name="action" class="form-select form-select-sm" required>
                        <option value="None">No Action</option>
                        <option value="WarningSent">Warning Sent</option>
                        <option value="Hidden">Content Hidden</option>
                        <option value="Deleted">Content Deleted</option>
                    </select>
                </div>
                <button type="submit" class="btn btn-success btn-sm">Submit Review</button>
            </form>
        }

        <form asp-action="Delete" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this report?')">
            <input type="hidden" name="id" value="@Model.Id" />
            <button type="submit" class="btn btn-outline-danger btn-sm">Delete Report</button>
        </form>
    </div>
</div>