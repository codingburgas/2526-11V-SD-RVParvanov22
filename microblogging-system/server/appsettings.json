{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=PlayerPulse.db"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Information"
    }
  },
  "AllowedHosts": "*",
  "JwtSettings": {
    "SecretKey": "your-super-secret-jwt-key-change-this-in-production-make-it-at-least-32-characters-long",
    "Issuer": "PlayerPulseApi",
    "Audience": "PlayerPulseApp",
    "ExpiryInMinutes": 60
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  }
}
